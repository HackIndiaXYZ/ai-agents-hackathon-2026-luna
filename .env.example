# TradeNexus Environment Configuration

# --- Supabase (PostgreSQL) ---
# Get these from your Supabase project: https://supabase.com/dashboard
SUPABASE_URL=
ANION_PUBLIC_KEY=
SERVICE_ROLE_KEY=

# --- Upstash Redis (REST API) ---
# Get these from your Upstash console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Nvidia API ---
# Get your API key from Nvidia Developer Portal: https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
LLM_PROVIDER=nvidia # nvidia | mock

# --- Security and Internal Keys ---
# Secret token to authorize internal administrative tasks and pipeline hooks
INTERNAL_KEY=

# --- Data.gov.in API ---
# Register and get your API key: https://data.gov.in/
DATA_GOV_API_KEY=

# --- Adaption AI API ---
# Get your API key from Adaption platform
ADAPTION_API_KEY=

# --- Google Routes API ---
# Get your API key from: https://console.cloud.google.com/ (Enable Routes API v2)
GOOGLE_ROUTES_API_KEY=

# --- App Environment ---
# Options: development, staging, production
ENVIRONMENT=development
